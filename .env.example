# Environment variables for agentic services
GEMINI_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=
PERPLEXITY_API_KEY=

# Clustering configuration overrides (optional)
CLUSTER_DATASET_DIR=
CLUSTER_MIN_CLUSTER_SIZE=
CLUSTER_MIN_SAMPLES=
CLUSTER_TRAINING_FRACTION=

# RL-Based Hyperparameter Optimization (NEW!)
# Enable/disable RL optimization for HDBSCAN (default: true)
CLUSTER_USE_RL_OPTIMIZATION=true

# Number of optimization trials - more trials = better results but slower (default: 20)
# Recommended: 10 (fast), 20 (balanced), 30+ (best quality)
CLUSTER_RL_N_TRIALS=20
